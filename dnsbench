def env_truthy(name: str) -> bool:
    value = os.environ.get(name, "").strip().lower()
    return value in {"1", "true", "yes", "on"}


def stdout_is_tty() -> bool:
    return bool(getattr(sys.stdout, "isatty", lambda: False)())


def stderr_is_tty() -> bool:
    return bool(getattr(sys.stderr, "isatty", lambda: False)())


def supports_unicode() -> bool:
    encoding = (sys.stdout.encoding or sys.getdefaultencoding() or "").lower()
    term = os.environ.get("TERM", "")
    return "utf" in encoding and term != "dumb"


def should_use_color(mode: ColorMode, stream) -> bool:
    if mode is ColorMode.ALWAYS:
        return True
    if mode is ColorMode.NEVER:
        return False
    if env_truthy("NO_COLOR"):
        return False
    return bool(getattr(stream, "isatty", lambda: False)()) and os.environ.get("TERM") != "dumb"


def paint(text: str, color: str, enabled: bool, *, bold: bool = False, dim: bool = False) -> str:
    if not enabled:
        return text
    prefix = ""
    if bold:
        prefix += Ansi.BOLD
    if dim:
        prefix += Ansi.DIM
    prefix += color
    return f"{prefix}{text}{Ansi.RESET}"


def clamp(value: float, low: float, high: float) -> float:
    return max(low, min(high, value))


def monotonic() -> float:
    return time.monotonic()


def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def human_duration(seconds: float | None) -> str:
    if seconds is None or math.isinf(seconds):
        return "∞"
    seconds = max(0.0, float(seconds))
    if seconds < 1:
        return f"{seconds * 1000:.0f}ms"
    minutes, sec = divmod(int(seconds), 60)
    hours, minutes = divmod(minutes, 60)
    if hours:
        return f"{hours:d}h{minutes:02d}m{sec:02d}s"
    if minutes:
        return f"{minutes:d}m{sec:02d}s"
    return f"{sec:d}s"


def format_ms(value: float | None, width: int = 8) -> str:
    if value is None or math.isnan(value):
        return "-".rjust(width)
    if value >= 10000:
        return f"{value / 1000:.2f}s".rjust(width)
    if value >= 1000:
        return f"{value / 1000:.3f}s".rjust(width)
    if value >= 100:
        return f"{value:.1f}".rjust(width)
    return f"{value:.2f}".rjust(width)


def format_rate(value: float | None) -> str:
    if value is None or value <= 0:
        return "-"
    if value >= 100:
        return f"{value:.0f}/s"
    if value >= 10:
        return f"{value:.1f}/s"
    return f"{value:.2f}/s"


def ellipsize(text: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(text) <= width:
        return text
    if width <= 1:
        return "…" if supports_unicode() else "."
    return text[: width - 1] + ("…" if supports_unicode() else ".")


def percentile(values: Sequence[float], pct: float) -> float | None:
    if not values:
        return None
    if len(values) == 1:
        return float(values[0])
    ordered = sorted(values)
    rank = (len(ordered) - 1) * pct
    lower = math.floor(rank)
    upper = math.ceil(rank)
    if lower == upper:
        return float(ordered[int(rank)])
    low_value = ordered[lower]
    high_value = ordered[upper]
    return float(low_value + (high_value - low_value) * (rank - lower))


def sparkline(values: Sequence[float], width: int, *, unicode: bool) -> str:
    chars = SPARK_CHARS_UNICODE if unicode else SPARK_CHARS_ASCII
    if width <= 0:
        return ""
    if not values:
        return "·" * width if unicode else "." * width
    data = list(values)[-width:]
    if len(data) < width:
        pad = ("·" if unicode else ".") * (width - len(data))
    else:
        pad = ""
    lo = min(data)
    hi = max(data)
    if math.isclose(lo, hi):
        body = chars[len(chars) // 2] * len(data)
    else:
        span = hi - lo
        body = "".join(chars[int(clamp((v - lo) / span, 0, 0.999999) * len(chars))] for v in data)
    return pad + body


def progress_bar(fraction: float, width: int, *, unicode: bool) -> str:
    fraction = clamp(fraction, 0.0, 1.0)
    filled = int(round(width * fraction))
    if unicode:
        return "█" * filled + "░" * (width - filled)
    return "#" * filled + "-" * (width - filled)


def normalize_domain(line: str) -> str | None:
    line = line.strip()
    if not line or line.startswith("#"):
        return None
    # Handle common hosts-file and adblock-list shapes without trying to be a
    # full parser. The whitelist this script uses is already simple, but this
    # lets the fallback path survive harmless format drift.
    if "#" in line:
        line = line.split("#", 1)[0].strip()
    parts = line.split()
    if not parts:
        return None
    if parts[0] in {"0.0.0.0", "127.0.0.1", "::1"} and len(parts) > 1:
        line = parts[1]
    else:
        line = parts[0]
    line = line.strip(". ").lower()
    if not line or "/" in line or "*" in line:
        return None
    if "." not in line:
        return None
    return line


def unique_stable(items: Iterable[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for item in items:
        if item not in seen:
            seen.add(item)
            result.append(item)
    return result


# ---------------------------------------------------------------------------
# Runtime stop state and signal handling.
# ---------------------------------------------------------------------------

STOP_EVENT = threading.Event()
_SHUTDOWN_LOCK = threading.Lock()
_SHUTDOWN_SIGNUM: int | None = None
_SHUTDOWN_REASON = "completed"


def signal_exit_code() -> int:
    with _SHUTDOWN_LOCK:
        if _SHUTDOWN_SIGNUM is None:
            return 130
        return 128 + _SHUTDOWN_SIGNUM


def shutdown_reason() -> str:
    with _SHUTDOWN_LOCK:
        return _SHUTDOWN_REASON


def request_shutdown(reason: str, signum: int | None = None) -> None:
    global _SHUTDOWN_SIGNUM, _SHUTDOWN_REASON
    with _SHUTDOWN_LOCK:
        if signum is not None and _SHUTDOWN_SIGNUM is None:
            _SHUTDOWN_SIGNUM = signum
        if _SHUTDOWN_REASON == "completed" or signum is not None:
            _SHUTDOWN_REASON = reason
    STOP_EVENT.set()


def _handle_shutdown_signal(signum: int, _frame) -> None:
    try:
        sig_name = signal.Signals(signum).name
    except ValueError:
        sig_name = f"signal {signum}"
    request_shutdown(sig_name, signum)
    # Raising KeyboardInterrupt wakes the main thread out of sleeps/waits.
    raise KeyboardInterrupt


def install_signal_handlers() -> None:
    signal.signal(signal.SIGINT, _handle_shutdown_signal)
    signal.signal(signal.SIGTERM, _handle_shutdown_signal)


def sleep_cooperatively(seconds: float, deadline: float | None = None) -> None:
    end = monotonic() + max(0.0, seconds)
    while not STOP_EVENT.is_set():
        now = monotonic()
        if deadline is not None and now >= deadline:
            return
        remaining = end - now
        if remaining <= 0:
            return
        if deadline is not None:
            remaining = min(remaining, max(0.0, deadline - now))
        time.sleep(min(remaining, 0.1))


