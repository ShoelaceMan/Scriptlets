def positive_float(value: str) -> float:
    try:
        parsed = float(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"not a number: {value}") from exc
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be > 0")
    return parsed


def nonnegative_float(value: str) -> float:
    try:
        parsed = float(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"not a number: {value}") from exc
    if parsed < 0:
        raise argparse.ArgumentTypeError("must be >= 0")
    return parsed


def positive_int(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"not an integer: {value}") from exc
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be > 0")
    return parsed


def nonnegative_int(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"not an integer: {value}") from exc
    if parsed < 0:
        raise argparse.ArgumentTypeError("must be >= 0")
    return parsed


class SmartFormatter(argparse.ArgumentDefaultsHelpFormatter, argparse.RawDescriptionHelpFormatter):
    pass


def build_parser() -> argparse.ArgumentParser:
    examples = textwrap.dedent(
        """
        examples:
          dnsbench                         # timed run, live UI if attached to a terminal
          dnsbench --duration 10           # benchmark for ten seconds
          dnsbench --continuous            # keep testing until Ctrl+C, preserving running averages
          dnsbench --ui live --color always
          dnsbench --output json --quiet   # machine-readable one-shot timed summary
          dnsbench --tcp --rdtype AAAA     # same servers, TCP transport, AAAA records
        """
    ).strip()
    parser = argparse.ArgumentParser(
        prog="dnsbench",
        description="Benchmark the hard-coded homelab DNS upstreams with health gates, live stats, and clean shutdown.",
        epilog=examples,
        formatter_class=SmartFormatter,
    )
    mode = parser.add_argument_group("run mode")
    mode.add_argument("-d", "--duration", type=positive_float, default=30.0, help="timed-run duration in seconds")
    mode.add_argument("-c", "--continuous", action="store_true", help="run until Ctrl+C instead of stopping at --duration")
    mode.add_argument("--interval", type=nonnegative_float, default=0.25, help="target pause between benchmark queries per healthy upstream")
    mode.add_argument("--jitter", type=nonnegative_float, default=0.15, help="fractional randomization applied to --interval")
    mode.add_argument("--warmup", type=nonnegative_int, default=1, help="successful uncounted warmup queries after a health pass")

    dns_group = parser.add_argument_group("dns behavior")
    dns_group.add_argument("--rdtype", default="A", help="DNS record type to benchmark")
    dns_group.add_argument("--tcp", action="store_true", help="use TCP instead of UDP for DNS queries")
    dns_group.add_argument("--query-timeout", type=positive_float, default=1.0, help="single resolver try timeout")
    dns_group.add_argument("--query-lifetime", type=positive_float, default=2.0, help="overall benchmark query lifetime")
    dns_group.add_argument("--fetch-timeout", type=positive_float, default=10.0, help="whitelist HTTP fetch timeout")
    dns_group.add_argument("--whitelist-url", default=WHITELIST_URL, help="domain whitelist URL; still no config file")
    dns_group.add_argument("--strict-whitelist", action="store_true", help="fail instead of using built-in fallback domains if whitelist fetch fails")

    health = parser.add_argument_group("health gate and quarantine")
    health.add_argument("--health-timeout", type=positive_float, default=0.75, help="single resolver try timeout for health checks")
    health.add_argument("--health-lifetime", type=positive_float, default=1.5, help="overall health-check query lifetime")
    health.add_argument("--health-retries", type=positive_int, default=1, help="passes over health-check domains before declaring unavailable")
    health.add_argument("--recheck-interval", type=positive_float, default=15.0, help="how long to quarantine an unavailable upstream before another health probe")
    health.add_argument("--failure-threshold", type=positive_int, default=3, help="consecutive benchmark failures before quarantining a formerly healthy upstream")

    ui = parser.add_argument_group("display")
    ui.add_argument("--ui", choices=[m.value for m in UIMode], default=UIMode.AUTO.value, help="terminal UI mode")
    ui.add_argument("--quiet", action="store_true", help="suppress progress UI; still prints final summary")
    ui.add_argument("--refresh", type=positive_float, default=0.20, help="live UI refresh interval")
    ui.add_argument("--snapshot-interval", type=nonnegative_float, default=5.0, help="plain-mode progress snapshot interval on stderr; 0 disables")
    ui.add_argument("--window", type=positive_int, default=200, help="rolling latency window for percentiles/window average")
    ui.add_argument("--spark-width", type=positive_int, default=24, help="sparkline width")
    ui.add_argument("--color", choices=[m.value for m in ColorMode], default=ColorMode.AUTO.value, help="color mode")
    glyphs = ui.add_mutually_exclusive_group()
    glyphs.add_argument("--unicode", action="store_true", help="force unicode glyphs")
    glyphs.add_argument("--ascii", action="store_true", help="force ASCII-only glyphs")

    output = parser.add_argument_group("output")
    output.add_argument("--output", choices=[m.value for m in OutputFormat], default=OutputFormat.TEXT.value, help="final summary format")
    output.add_argument("--seed", type=int, default=None, help="random seed for repeatable domain ordering")
    output.add_argument("--version", action="version", version=f"%(prog)s {SCRIPT_VERSION}")
    return parser


def settings_from_args(args: argparse.Namespace) -> BenchmarkSettings:
    ui_mode = UIMode.QUIET if args.quiet else UIMode(args.ui)
    force_unicode: bool | None
    if args.unicode:
        force_unicode = True
    elif args.ascii:
        force_unicode = False
    else:
        force_unicode = None
    return BenchmarkSettings(
        duration=None if args.continuous else args.duration,
        continuous=bool(args.continuous),
        interval=args.interval,
        jitter=clamp(args.jitter, 0.0, 1.0),
        query_timeout=args.query_timeout,
        query_lifetime=args.query_lifetime,
        health_timeout=args.health_timeout,
        health_lifetime=args.health_lifetime,
        health_retries=args.health_retries,
        recheck_interval=args.recheck_interval,
        failure_quarantine_threshold=args.failure_threshold,
        warmup_queries=args.warmup,
        record_type=args.rdtype.upper(),
        tcp=bool(args.tcp),
        refresh_interval=args.refresh,
        snapshot_interval=args.snapshot_interval,
        window_size=args.window,
        spark_width=args.spark_width,
        seed=args.seed,
        fetch_timeout=args.fetch_timeout,
        whitelist_url=args.whitelist_url,
        output_format=OutputFormat(args.output),
        ui_mode=ui_mode,
        color_mode=ColorMode(args.color),
        force_unicode=force_unicode,
        strict_whitelist=bool(args.strict_whitelist),
    )


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    settings = settings_from_args(args)
    app = DNSBenchApp(settings)
    try:
        return app.run()
    except RuntimeError as exc:
        print(f"dnsbench: {exc}", file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        request_shutdown("KeyboardInterrupt", signal.SIGINT)
        return signal_exit_code()


if __name__ == "__main__":
    sys.exit(main())
