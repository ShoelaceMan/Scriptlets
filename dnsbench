class DomainDeck:
    """Thread-safe weighted-random-ish draw pile for benchmark domains."""

    def __init__(self, domains: Sequence[str], seed: int | None):
        if not domains:
            raise ValueError("Domain list is empty")
        self._domains = list(domains)
        self._random = random.Random(seed)
        self._lock = threading.Lock()
        self._deck: list[str] = []
        self._refills = 0

    @property
    def size(self) -> int:
        return len(self._domains)

    @property
    def refills(self) -> int:
        with self._lock:
            return self._refills

    def draw(self) -> str:
        with self._lock:
            if not self._deck:
                self._deck = list(self._domains)
                self._random.shuffle(self._deck)
                self._refills += 1
            return self._deck.pop()


def fetch_domains(settings: BenchmarkSettings) -> tuple[list[str], str]:
    """Fetch and normalize the whitelist; optionally fall back to built-ins."""
    try:
        response = requests.get(settings.whitelist_url, timeout=settings.fetch_timeout)
        response.raise_for_status()
        raw_domains = [normalize_domain(line) for line in response.text.splitlines()]
        domains = unique_stable(d for d in raw_domains if d)
        if not domains:
            raise ValueError("whitelist fetched successfully but contained no usable domains")
        return domains, settings.whitelist_url
    except Exception as exc:  # noqa: BLE001 - fallback path is intentionally broad
        if settings.strict_whitelist:
            raise RuntimeError(f"Unable to fetch whitelist from {settings.whitelist_url}: {exc}") from exc
        domains = unique_stable(d for d in FALLBACK_DOMAINS if normalize_domain(d))
        print(
            f"Whitelist fetch failed ({exc!r}); using {len(domains)} built-in fallback domains.",
            file=sys.stderr,
        )
        return domains, "built-in fallback"


class DNSClient:
    def __init__(self, settings: BenchmarkSettings):
        self.settings = settings

    def query(
        self,
        server: NameServer,
        domain: str,
        *,
        rdtype: str | None = None,
        timeout: float | None = None,
        lifetime: float | None = None,
    ) -> QueryOutcome:
        rdtype = (rdtype or self.settings.record_type).upper()
        timeout = self.settings.query_timeout if timeout is None else timeout
        lifetime = self.settings.query_lifetime if lifetime is None else lifetime
        resolver = dns.resolver.Resolver(configure=False)
        resolver.nameservers = [server.address]
        resolver.timeout = timeout
        resolver.lifetime = lifetime
        resolver.retry_servfail = False
        start = monotonic()
        try:
            answer = resolver.resolve(domain, rdtype, tcp=self.settings.tcp)
            latency_ms = (monotonic() - start) * 1000.0
            answer_count = len(answer) if answer is not None else 0
            return QueryOutcome(
                ok=True,
                latency_ms=latency_ms,
                domain=domain,
                rdtype=rdtype,
                answer_count=answer_count,
            )
        except dns.resolver.Timeout as exc:
            return QueryOutcome(False, None, domain, rdtype, "timeout", str(exc))
        except dns.resolver.NXDOMAIN as exc:
            return QueryOutcome(False, None, domain, rdtype, "nxdomain", str(exc))
        except dns.resolver.NoAnswer as exc:
            return QueryOutcome(False, None, domain, rdtype, "no-answer", str(exc))
        except dns.resolver.NoNameservers as exc:
            return QueryOutcome(False, None, domain, rdtype, "no-nameservers", str(exc))
        except dns.resolver.YXDOMAIN as exc:
            return QueryOutcome(False, None, domain, rdtype, "yxdomain", str(exc))
        except dns.exception.DNSException as exc:
            return QueryOutcome(False, None, domain, rdtype, exc.__class__.__name__, str(exc))
        except OSError as exc:
            return QueryOutcome(False, None, domain, rdtype, exc.__class__.__name__, str(exc))


# ---------------------------------------------------------------------------
# Worker logic: health gate, quarantine, paced benchmark loop.
# ---------------------------------------------------------------------------

def should_continue(deadline: float | None) -> bool:
    if STOP_EVENT.is_set():
        return False
    if deadline is not None and monotonic() >= deadline:
        return False
    return True


def jittered_interval(base: float, jitter: float, rng: random.Random) -> float:
    if base <= 0:
        return 0.0
    jitter = clamp(jitter, 0.0, 1.0)
    if jitter == 0:
        return base
    return max(0.0, base * (1.0 + rng.uniform(-jitter, jitter)))


def run_health_check(
    server: NameServer,
    state: ServerState,
    client: DNSClient,
    settings: BenchmarkSettings,
    health_queries: Sequence[tuple[str, str]],
    deadline: float | None,
) -> bool:
    last_outcome = QueryOutcome(False, None, "-", settings.record_type, "not-run", "health check did not run")
    attempted = False
    exhausted = False
    for attempt in range(max(1, settings.health_retries)):
        if STOP_EVENT.is_set():
            if attempted:
                break
            return False
        if deadline is not None and monotonic() >= deadline:
            break
        for domain, rdtype in health_queries:
            if STOP_EVENT.is_set():
                break
            if deadline is not None and monotonic() >= deadline:
                break
            outcome = client.query(
                server,
                domain,
                rdtype=rdtype,
                timeout=settings.health_timeout,
                lifetime=settings.health_lifetime,
            )
            attempted = True
            last_outcome = outcome
            if outcome.ok:
                state.mark_health_success(outcome)
                return True
        else:
            if attempt + 1 < settings.health_retries:
                sleep_cooperatively(min(0.25, settings.health_lifetime / 4), deadline)
                continue
            exhausted = True
        break

    if attempted or exhausted:
        next_health_at = monotonic() + settings.recheck_interval
        state.mark_health_failure(last_outcome, next_health_at)
    return False


def server_worker(
    server: NameServer,
    state: ServerState,
    deck: DomainDeck,
    client: DNSClient,
    settings: BenchmarkSettings,
    health_queries: Sequence[tuple[str, str]],
    deadline: float | None,
) -> None:
    rng_seed = (settings.seed if settings.seed is not None else time.monotonic_ns()) ^ hash(server.address)
    rng = random.Random(rng_seed)
    warmup_remaining = max(0, settings.warmup_queries)

    try:
        state.set_phase(Phase.CHECKING, Verdict.UNKNOWN, "initial health gate")
        while should_continue(deadline):
            snapshot = state.snapshot()
            health_ok = snapshot["health_ok"] is True

            if not health_ok:
                state.set_phase(Phase.CHECKING, Verdict.UNKNOWN, "probing upstream availability")
                if run_health_check(server, state, client, settings, health_queries, deadline):
                    warmup_remaining = max(0, settings.warmup_queries)
                    continue
                # Health checks are the only traffic sent to an unavailable
                # upstream. Sleep until the next bounded recheck window.
                next_in = state.snapshot().get("next_health_in_s")
                sleep_cooperatively(float(next_in or settings.recheck_interval), deadline)
                continue

            if warmup_remaining > 0:
                state.set_phase(Phase.WARMING, Verdict.HEALTHY, f"{warmup_remaining} warmup query(s) left")
                domain = deck.draw()
                outcome = client.query(server, domain)
                state.mark_warmup(outcome)
                if outcome.ok:
                    warmup_remaining -= 1
                elif state.snapshot()["consecutive_failures"] >= settings.failure_quarantine_threshold:
                    next_health_at = monotonic() + settings.recheck_interval
                    state.mark_benchmark_failure(
                        outcome,
                        threshold=settings.failure_quarantine_threshold,
                        next_health_at=next_health_at,
                    )
                sleep_cooperatively(jittered_interval(settings.interval, settings.jitter, rng), deadline)
                continue

            state.set_phase(Phase.TESTING, Verdict.HEALTHY, "benchmarking")
            domain = deck.draw()
            outcome = client.query(server, domain)
            if outcome.ok:
                state.mark_benchmark_success(outcome)
            else:
                next_health_at = monotonic() + settings.recheck_interval
                state.mark_benchmark_failure(
                    outcome,
                    threshold=settings.failure_quarantine_threshold,
                    next_health_at=next_health_at,
                )
            sleep_cooperatively(jittered_interval(settings.interval, settings.jitter, rng), deadline)
    except Exception as exc:  # noqa: BLE001 - worker death gets recorded, not hidden
        state.set_phase(Phase.QUARANTINED, Verdict.UNAVAILABLE, f"worker crashed: {exc!r}")
    finally:
        state.mark_done()


