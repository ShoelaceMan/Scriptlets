class OnlineLatencyStats:
    """Online average/variance plus a bounded percentile/sparkline window."""

    def __init__(self, window_size: int, spark_width: int, ewma_alpha: float = 0.20):
        self.n = 0
        self.mean = 0.0
        self.m2 = 0.0
        self.min_value: float | None = None
        self.max_value: float | None = None
        self.ewma: float | None = None
        self.window: deque[float] = deque(maxlen=max(2, window_size))
        self.spark_values: deque[float] = deque(maxlen=max(2, spark_width))
        self.ewma_alpha = clamp(ewma_alpha, 0.01, 1.0)

    def add(self, value: float) -> None:
        self.n += 1
        delta = value - self.mean
        self.mean += delta / self.n
        delta2 = value - self.mean
        self.m2 += delta * delta2
        self.min_value = value if self.min_value is None else min(self.min_value, value)
        self.max_value = value if self.max_value is None else max(self.max_value, value)
        self.ewma = value if self.ewma is None else (self.ewma_alpha * value + (1 - self.ewma_alpha) * self.ewma)
        self.window.append(value)
        self.spark_values.append(value)

    @property
    def variance(self) -> float | None:
        if self.n < 2:
            return None
        return self.m2 / (self.n - 1)

    @property
    def stdev(self) -> float | None:
        variance = self.variance
        return math.sqrt(variance) if variance is not None else None

    def snapshot(self) -> dict[str, object]:
        win = list(self.window)
        return {
            "samples": self.n,
            "avg_ms": self.mean if self.n else None,
            "ewma_ms": self.ewma,
            "stdev_ms": self.stdev,
            "min_ms": self.min_value,
            "max_ms": self.max_value,
            "window_avg_ms": statistics.mean(win) if win else None,
            "p50_ms": percentile(win, 0.50),
            "p90_ms": percentile(win, 0.90),
            "p95_ms": percentile(win, 0.95),
            "p99_ms": percentile(win, 0.99),
            "spark_values": tuple(self.spark_values),
        }


class ServerState:
    """Thread-safe, over-narrated state for one upstream."""

    def __init__(self, server: NameServer, *, window_size: int, spark_width: int):
        self.server = server
        self._lock = threading.RLock()
        self._stats = OnlineLatencyStats(window_size=window_size, spark_width=spark_width)
        self.created_at = monotonic()
        self.started_at: float | None = None
        self.last_activity_at: float | None = None
        self.last_success_at: float | None = None
        self.last_failure_at: float | None = None
        self.last_health_at: float | None = None
        self.next_health_at: float | None = None
        self.phase = Phase.QUEUED
        self.verdict = Verdict.UNKNOWN
        self.health_ok: bool | None = None
        self.health_checks = 0
        self.health_failures = 0
        self.health_successes = 0
        self.benchmark_failures = 0
        self.warmup_successes = 0
        self.warmup_failures = 0
        self.consecutive_failures = 0
        self.total_benchmark_attempts = 0
        self.last_latency_ms: float | None = None
        self.last_domain: str | None = None
        self.last_rdtype: str | None = None
        self.last_error: str | None = None
        self.last_detail: str | None = None
        self.error_counts: Counter[str] = Counter()
        self.recoveries = 0
        self.quarantines = 0

    def set_phase(self, phase: Phase, verdict: Verdict | None = None, detail: str | None = None) -> None:
        with self._lock:
            self.phase = phase
            if verdict is not None:
                self.verdict = verdict
            if detail is not None:
                self.last_detail = detail
            self.last_activity_at = monotonic()

    def mark_health_success(self, outcome: QueryOutcome) -> None:
        with self._lock:
            was_down = self.health_ok is False
            self.health_checks += 1
            self.health_successes += 1
            self.health_ok = True
            self.phase = Phase.ONLINE
            self.verdict = Verdict.HEALTHY
            self.last_health_at = monotonic()
            self.next_health_at = None
            self.last_activity_at = self.last_health_at
            self.last_latency_ms = outcome.latency_ms
            self.last_domain = outcome.domain
            self.last_rdtype = outcome.rdtype
            self.last_error = None
            self.last_detail = f"health ok: {outcome.domain} {outcome.rdtype}"
            self.consecutive_failures = 0
            if was_down:
                self.recoveries += 1

    def mark_health_failure(self, outcome: QueryOutcome, next_health_at: float) -> None:
        with self._lock:
            self.health_checks += 1
            self.health_failures += 1
            self.health_ok = False
            self.phase = Phase.QUARANTINED
            self.verdict = Verdict.UNAVAILABLE
            self.last_health_at = monotonic()
            self.next_health_at = next_health_at
            self.last_activity_at = self.last_health_at
            self.last_domain = outcome.domain
            self.last_rdtype = outcome.rdtype
            self.last_error = outcome.error_kind or "health-failed"
            self.last_detail = outcome.detail or "health check failed"
            self.error_counts[self.last_error] += 1

    def mark_warmup(self, outcome: QueryOutcome) -> None:
        with self._lock:
            self.phase = Phase.WARMING
            self.last_activity_at = monotonic()
            self.last_domain = outcome.domain
            self.last_rdtype = outcome.rdtype
            self.last_latency_ms = outcome.latency_ms
            if outcome.ok:
                self.warmup_successes += 1
                self.consecutive_failures = 0
                self.last_error = None
                self.last_detail = "warmup ok"
            else:
                self.warmup_failures += 1
                self.consecutive_failures += 1
                self.last_error = outcome.error_kind or "warmup-failed"
                self.last_detail = outcome.detail or "warmup failed"
                self.error_counts[self.last_error] += 1

    def mark_benchmark_success(self, outcome: QueryOutcome) -> None:
        with self._lock:
            now = monotonic()
            if self.started_at is None:
                self.started_at = now
            self.total_benchmark_attempts += 1
            self._stats.add(float(outcome.latency_ms or 0.0))
            self.phase = Phase.TESTING
            self.verdict = Verdict.HEALTHY
            self.health_ok = True
            self.last_activity_at = now
            self.last_success_at = now
            self.last_latency_ms = outcome.latency_ms
            self.last_domain = outcome.domain
            self.last_rdtype = outcome.rdtype
            self.last_error = None
            self.last_detail = f"{outcome.answer_count or 0} answer(s)"
            self.consecutive_failures = 0

    def mark_benchmark_failure(self, outcome: QueryOutcome, *, threshold: int, next_health_at: float) -> None:
        with self._lock:
            now = monotonic()
            if self.started_at is None:
                self.started_at = now
            self.total_benchmark_attempts += 1
            self.benchmark_failures += 1
            self.consecutive_failures += 1
            self.last_activity_at = now
            self.last_failure_at = now
            self.last_domain = outcome.domain
            self.last_rdtype = outcome.rdtype
            self.last_error = outcome.error_kind or "query-failed"
            self.last_detail = outcome.detail or "benchmark query failed"
            self.error_counts[self.last_error] += 1
            if self.consecutive_failures >= threshold:
                self.health_ok = False
                self.phase = Phase.QUARANTINED
                self.verdict = Verdict.UNAVAILABLE
                self.next_health_at = next_health_at
                self.quarantines += 1
            else:
                self.phase = Phase.TESTING
                self.verdict = Verdict.DEGRADED

    def mark_stopping(self) -> None:
        with self._lock:
            self.phase = Phase.STOPPING
            self.last_activity_at = monotonic()

    def mark_done(self) -> None:
        with self._lock:
            # DONE is a phase, not a health verdict. Preserve the last useful
            # resolver verdict so final summaries answer the question the user
            # actually cares about: healthy/degraded/unavailable.
            if self.verdict is Verdict.UNKNOWN and STOP_EVENT.is_set():
                self.verdict = Verdict.STOPPED
            self.phase = Phase.DONE
            self.last_activity_at = monotonic()

    def snapshot(self) -> dict[str, object]:
        with self._lock:
            stats = self._stats.snapshot()
            now = monotonic()
            elapsed = None
            if self.started_at is not None:
                elapsed = max(0.0, now - self.started_at)
            attempts = self.total_benchmark_attempts
            samples = int(stats["samples"])
            fail_pct = (self.benchmark_failures / attempts * 100.0) if attempts else None
            qps = (attempts / elapsed) if elapsed and elapsed > 0 else None
            return {
                "server": dataclasses.asdict(self.server),
                "display": self.server.display,
                "phase": self.phase.value,
                "verdict": self.verdict.value,
                "health_ok": self.health_ok,
                "health_checks": self.health_checks,
                "health_successes": self.health_successes,
                "health_failures": self.health_failures,
                "benchmark_attempts": attempts,
                "benchmark_failures": self.benchmark_failures,
                "failure_percent": fail_pct,
                "consecutive_failures": self.consecutive_failures,
                "warmup_successes": self.warmup_successes,
                "warmup_failures": self.warmup_failures,
                "recoveries": self.recoveries,
                "quarantines": self.quarantines,
                "last_latency_ms": self.last_latency_ms,
                "last_domain": self.last_domain,
                "last_rdtype": self.last_rdtype,
                "last_error": self.last_error,
                "last_detail": self.last_detail,
                "next_health_in_s": max(0.0, self.next_health_at - now) if self.next_health_at else None,
                "qps": qps,
                "error_counts": dict(self.error_counts),
                **stats,
            }


