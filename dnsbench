class BaseRenderer:
    def __init__(self, settings: BenchmarkSettings, *, unicode: bool, color: bool):
        self.settings = settings
        self.unicode = unicode
        self.color = color
        self.frame = 0

    def render(self, *_args, **_kwargs) -> None:
        return None

    def close(self) -> None:
        return None


class QuietRenderer(BaseRenderer):
    pass


class PlainRenderer(BaseRenderer):
    def __init__(self, settings: BenchmarkSettings, *, unicode: bool, color: bool):
        super().__init__(settings, unicode=unicode, color=color)
        self.next_snapshot_at = 0.0

    def render(
        self,
        states: Sequence[ServerState],
        *,
        start_time: float,
        deadline: float | None,
        domain_count: int,
        source: str,
    ) -> None:
        now = monotonic()
        if self.next_snapshot_at == 0.0:
            self.next_snapshot_at = now + self.settings.snapshot_interval
            print(
                f"dnsbench started: servers={len(states)} domains={domain_count} source={source} "
                f"duration={human_duration(None if deadline is None else max(0.0, deadline - start_time))} "
                f"mode={'continuous' if deadline is None else 'timed'}",
                file=sys.stderr,
                flush=True,
            )
            return
        if self.settings.snapshot_interval <= 0 or now < self.next_snapshot_at:
            return
        self.next_snapshot_at = now + self.settings.snapshot_interval
        snaps = [s.snapshot() for s in states]
        healthy = sum(1 for s in snaps if s["health_ok"] is True)
        samples = sum(int(s["samples"]) for s in snaps)
        failures = sum(int(s["benchmark_failures"]) for s in snaps)
        elapsed = now - start_time
        remaining = None if deadline is None else max(0.0, deadline - now)
        print(
            f"dnsbench snapshot: elapsed={human_duration(elapsed)} remaining={human_duration(remaining)} "
            f"healthy={healthy}/{len(snaps)} samples={samples} failures={failures}",
            file=sys.stderr,
            flush=True,
        )


class LiveRenderer(BaseRenderer):
    def __init__(self, settings: BenchmarkSettings, *, unicode: bool, color: bool):
        super().__init__(settings, unicode=unicode, color=color)
        self._opened = False

    def _spinner(self) -> str:
        frames = SPINNER_FRAMES_UNICODE if self.unicode else SPINNER_FRAMES_ASCII
        return frames[self.frame % len(frames)]

    def _scanner(self) -> str:
        frames = SCANNER_FRAMES_UNICODE if self.unicode else SCANNER_FRAMES_ASCII
        return frames[self.frame % len(frames)]

    def _verdict_icon(self, snap: dict[str, object]) -> str:
        verdict = snap["verdict"]
        phase = snap["phase"]
        if self.unicode:
            if verdict == Verdict.HEALTHY.value:
                return paint("●", Ansi.GREEN, self.color)
            if verdict == Verdict.DEGRADED.value:
                return paint("▲", Ansi.YELLOW, self.color)
            if verdict == Verdict.UNAVAILABLE.value:
                return paint("●", Ansi.RED, self.color)
            if phase in {Phase.CHECKING.value, Phase.QUEUED.value}:
                return paint("◌", Ansi.CYAN, self.color)
            return paint("○", Ansi.GREY, self.color)
        if verdict == Verdict.HEALTHY.value:
            return paint("OK", Ansi.GREEN, self.color)
        if verdict == Verdict.DEGRADED.value:
            return paint("!!", Ansi.YELLOW, self.color)
        if verdict == Verdict.UNAVAILABLE.value:
            return paint("NO", Ansi.RED, self.color)
        return "--"

    def _status_text(self, snap: dict[str, object]) -> str:
        phase = str(snap["phase"])
        if phase == Phase.QUARANTINED.value:
            next_in = snap.get("next_health_in_s")
            if isinstance(next_in, (int, float)):
                return f"quarantine {human_duration(next_in)}"
        return phase

    def render(
        self,
        states: Sequence[ServerState],
        *,
        start_time: float,
        deadline: float | None,
        domain_count: int,
        source: str,
    ) -> None:
        if not self._opened:
            sys.stdout.write(Ansi.HIDE_CURSOR)
            self._opened = True
        now = monotonic()
        elapsed = now - start_time
        remaining = None if deadline is None else max(0.0, deadline - now)
        snaps = [s.snapshot() for s in states]
        healthy = sum(1 for s in snaps if s["health_ok"] is True)
        samples = sum(int(s["samples"]) for s in snaps)
        failures = sum(int(s["benchmark_failures"]) for s in snaps)
        width = max(80, os.get_terminal_size().columns if stdout_is_tty() else 120)

        title = f"{self._spinner()} dnsbench // homelab resolver telemetry extravaganza"
        title = paint(title, Ansi.CYAN, self.color, bold=True)
        mode = "continuous" if deadline is None else "timed"
        if deadline is None:
            bar = self._scanner()
            progress = f"{bar} elapsed {human_duration(elapsed)}"
        else:
            duration = max(0.001, self.settings.duration or 1.0)
            fraction = clamp(elapsed / duration, 0, 1)
            bar = progress_bar(fraction, min(34, max(12, width - 86)), unicode=self.unicode)
            progress = f"[{bar}] {fraction * 100:5.1f}% remaining {human_duration(remaining)}"

        header = (
            f"{title}\n"
            f"mode={mode} transport={self.settings.transport} rdtype={self.settings.record_type} "
            f"servers={healthy}/{len(states)} healthy domains={domain_count} "
            f"samples={samples} bench_failures={failures} source={source}\n"
            f"{progress}\n"
        )

        table_width = width
        spark_width = min(self.settings.spark_width, max(8, width - 112))
        columns = (
            f"{' ':2} {'Server':22} {'State':15} {'Last':>8} {'Avg':>8} {'EWMA':>8} "
            f"{'P50':>8} {'P95':>8} {'Samples':>7} {'Err%':>6} {'Rate':>7} {'Trend':{spark_width}}"
        )
        sep = "─" * min(table_width, len(strip_ansi(columns))) if self.unicode else "-" * min(table_width, len(strip_ansi(columns)))
        rows = []
        for snap in snaps:
            icon = self._verdict_icon(snap)
            display = ellipsize(str(snap["display"]), 22)
            state = ellipsize(self._status_text(snap), 15)
            spark = sparkline(snap["spark_values"], spark_width, unicode=self.unicode)
            err_pct = snap["failure_percent"]
            err_s = "-" if err_pct is None else f"{float(err_pct):5.1f}%"
            row = (
                f"{icon:2} {display:22} {state:15} "
                f"{format_ms(snap['last_latency_ms'])} {format_ms(snap['avg_ms'])} "
                f"{format_ms(snap['ewma_ms'])} {format_ms(snap['p50_ms'])} "
                f"{format_ms(snap['p95_ms'])} {int(snap['samples']):7d} "
                f"{err_s:>6} {format_rate(snap['qps']):>7} {spark:{spark_width}}"
            )
            if snap["verdict"] == Verdict.UNAVAILABLE.value:
                row = paint(row, Ansi.RED, self.color, dim=True)
            elif snap["verdict"] == Verdict.DEGRADED.value:
                row = paint(row, Ansi.YELLOW, self.color)
            elif snap["verdict"] == Verdict.HEALTHY.value:
                row = paint(row, Ansi.GREEN, self.color)
            rows.append(row)

        footer_bits = []
        leader = best_server(snaps)
        if leader:
            footer_bits.append(f"leader={leader['display']} avg={format_ms(leader['avg_ms']).strip()}ms")
        latest_errors = [
            f"{s['server']['label']}:{s['last_error']}"
            for s in snaps
            if s.get("last_error") and s.get("verdict") != Verdict.HEALTHY.value
        ]
        if latest_errors:
            footer_bits.append("errors=" + ", ".join(ellipsize(e, 24) for e in latest_errors[:3]))
        footer_bits.append("Ctrl+C stops cleanly")
        footer = " | ".join(footer_bits)

        screen = header + columns + "\n" + sep + "\n" + "\n".join(rows) + "\n\n" + paint(footer, Ansi.DIM, self.color) + "\n"
        sys.stdout.write(Ansi.CLEAR + screen)
        sys.stdout.flush()
        self.frame += 1

    def close(self) -> None:
        if self._opened:
            sys.stdout.write(Ansi.SHOW_CURSOR)
            sys.stdout.flush()
            self._opened = False


def strip_ansi(text: str) -> str:
    # Tiny local stripper for width math; good enough for our own SGR codes.
    out = []
    i = 0
    while i < len(text):
        if text[i] == "\033":
            j = i + 1
            while j < len(text) and text[j] != "m":
                j += 1
            i = j + 1
            continue
        out.append(text[i])
        i += 1
    return "".join(out)


def choose_renderer(settings: BenchmarkSettings) -> BaseRenderer:
    unicode = settings.force_unicode if settings.force_unicode is not None else supports_unicode()
    color = should_use_color(settings.color_mode, sys.stdout)
    if settings.output_format is not OutputFormat.TEXT:
        return QuietRenderer(settings, unicode=unicode, color=color)
    if settings.ui_mode is UIMode.QUIET:
        return QuietRenderer(settings, unicode=unicode, color=color)
    if settings.ui_mode is UIMode.LIVE or (settings.ui_mode is UIMode.AUTO and stdout_is_tty()):
        return LiveRenderer(settings, unicode=unicode, color=color)
    return PlainRenderer(settings, unicode=unicode, color=should_use_color(settings.color_mode, sys.stderr))


