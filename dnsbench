def best_server(snaps: Sequence[dict[str, object]]) -> dict[str, object] | None:
    candidates = [s for s in snaps if isinstance(s.get("avg_ms"), (int, float)) and int(s.get("samples", 0)) > 0]
    if not candidates:
        return None
    return min(candidates, key=lambda s: (float(s["avg_ms"]), float(s.get("p95_ms") or 1e99)))


def ranked_snaps(snaps: Sequence[dict[str, object]]) -> list[dict[str, object]]:
    return sorted(
        snaps,
        key=lambda s: (
            0 if isinstance(s.get("avg_ms"), (int, float)) else 1,
            float(s.get("avg_ms") or 1e99),
            str(s["display"]),
        ),
    )


def build_summary(
    states: Sequence[ServerState],
    *,
    settings: BenchmarkSettings,
    start_time: float,
    end_time: float,
    domain_count: int,
    domain_source: str,
    pending_workers: int,
    interrupted: bool,
) -> dict[str, object]:
    snaps = [s.snapshot() for s in states]
    leader = best_server(snaps)
    return {
        "script": "dnsbench",
        "version": SCRIPT_VERSION,
        "started_at_utc": datetime.fromtimestamp(time.time() - (end_time - start_time), tz=timezone.utc).isoformat(timespec="seconds"),
        "ended_at_utc": utc_now_iso(),
        "elapsed_s": end_time - start_time,
        "mode": "continuous" if settings.continuous else "timed",
        "duration_s": settings.duration,
        "interrupted": interrupted,
        "shutdown_reason": shutdown_reason(),
        "pending_workers_after_shutdown": pending_workers,
        "transport": settings.transport,
        "record_type": settings.record_type,
        "domain_count": domain_count,
        "domain_source": domain_source,
        "settings": {
            "interval_s": settings.interval,
            "jitter": settings.jitter,
            "query_timeout_s": settings.query_timeout,
            "query_lifetime_s": settings.query_lifetime,
            "health_timeout_s": settings.health_timeout,
            "health_lifetime_s": settings.health_lifetime,
            "health_retries": settings.health_retries,
            "recheck_interval_s": settings.recheck_interval,
            "failure_quarantine_threshold": settings.failure_quarantine_threshold,
            "warmup_queries": settings.warmup_queries,
            "window_size": settings.window_size,
        },
        "leader": leader["server"] if leader else None,
        "servers": ranked_snaps(snaps),
    }


