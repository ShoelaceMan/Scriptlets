        "samples",
        "benchmark_attempts",
        "benchmark_failures",
        "failure_percent",
        "qps",
        "last_error",
        "last_domain",
    ]
    writer = csv.DictWriter(sys.stdout, fieldnames=fieldnames)
    writer.writeheader()
    rank = 0
    for snap in summary["servers"]:
        server = snap["server"]
        if isinstance(snap.get("avg_ms"), (int, float)):
            rank += 1
            rank_value: int | str = rank
        else:
            rank_value = ""
        writer.writerow(
            {
                "rank": rank_value,
                "label": server["label"],
                "address": server["address"],
                "verdict": snap["verdict"],
                "health_ok": snap["health_ok"],
                "avg_ms": snap["avg_ms"],
                "window_avg_ms": snap["window_avg_ms"],
                "p50_ms": snap["p50_ms"],
                "p95_ms": snap["p95_ms"],
                "min_ms": snap["min_ms"],
                "max_ms": snap["max_ms"],
                "samples": snap["samples"],
                "benchmark_attempts": snap["benchmark_attempts"],
                "benchmark_failures": snap["benchmark_failures"],
                "failure_percent": snap["failure_percent"],
                "qps": snap["qps"],
                "last_error": snap["last_error"],
                "last_domain": snap["last_domain"],
            }
        )


def print_summary(summary: dict[str, object], output_format: OutputFormat) -> None:
    if output_format is OutputFormat.JSON:
        print_json_summary(summary)
    elif output_format is OutputFormat.CSV:
        print_csv_summary(summary)
    else:
        print_text_summary(summary)


# ---------------------------------------------------------------------------
# Orchestrator.
# ---------------------------------------------------------------------------

class DNSBenchApp:
    def __init__(self, settings: BenchmarkSettings):
        self.settings = settings
        self.servers = NameServer.all()
        self.states = [
            ServerState(server, window_size=settings.window_size, spark_width=settings.spark_width)
            for server in self.servers
        ]
        self.client = DNSClient(settings)
        self.domain_deck: DomainDeck | None = None
        self.domain_count = 0
        self.domain_source = "unknown"
        self.deadline: float | None = None
        self.start_time: float | None = None
        self.end_time: float | None = None
        self.pending_workers = 0
        self.interrupted = False

    def load_domains(self) -> None:
        domains, source = fetch_domains(self.settings)
        self.domain_deck = DomainDeck(domains, self.settings.seed)
        self.domain_count = len(domains)
        self.domain_source = source

    def run(self) -> int:
        install_signal_handlers()
        self.load_domains()
        assert self.domain_deck is not None
        self.start_time = monotonic()
        self.deadline = None if self.settings.continuous else self.start_time + float(self.settings.duration or 0)
        renderer = choose_renderer(self.settings)
        executor = concurrent.futures.ThreadPoolExecutor(
            max_workers=len(self.servers),
            thread_name_prefix="dnsbench",
        )
        futures: list[concurrent.futures.Future[None]] = []

        for server, state in zip(self.servers, self.states, strict=True):
            futures.append(
                executor.submit(
                    server_worker,
                    server,
                    state,
                    self.domain_deck,
                    self.client,
                    self.settings,
                    DEFAULT_HEALTHCHECK_QUERIES,
                    self.deadline,
                )
            )

        exit_code = 0
        try:
            while should_continue(self.deadline):
                renderer.render(
                    self.states,
                    start_time=self.start_time,
                    deadline=self.deadline,
                    domain_count=self.domain_count,
                    source=self.domain_source,
                )
                sleep_cooperatively(self.settings.refresh_interval, self.deadline)
            request_shutdown("duration elapsed" if self.deadline is not None else "completed")
        except KeyboardInterrupt:
            self.interrupted = True
            exit_code = signal_exit_code()
            reason = shutdown_reason()
            if self.settings.output_format is OutputFormat.TEXT and not isinstance(renderer, LiveRenderer):
                print(f"Interrupted by {reason}; stopping cleanly...", file=sys.stderr, flush=True)
        finally:
            request_shutdown(shutdown_reason())
            for state in self.states:
                state.mark_stopping()
            for future in futures:
                future.cancel()
            executor.shutdown(wait=False, cancel_futures=True)
            wait_timeout = max(self.settings.query_lifetime, self.settings.health_lifetime) + 0.75
            _, pending = concurrent.futures.wait(futures, timeout=wait_timeout)
            self.pending_workers = len(pending)
            for state in self.states:
                state.mark_done()
            self.end_time = monotonic()
            renderer.close()

        # Worker exceptions are already represented by state, but consume them so
        # Python cannot complain about unobserved future failures in odd runtimes.
        for future in futures:
            if future.done() and not future.cancelled():
                try:
                    future.result(timeout=0)
                except Exception:
                    pass

        summary = build_summary(
            self.states,
            settings=self.settings,
            start_time=self.start_time,
            end_time=self.end_time,
            domain_count=self.domain_count,
            domain_source=self.domain_source,
            pending_workers=self.pending_workers,
            interrupted=self.interrupted,
        )
        print_summary(summary, self.settings.output_format)

        if self.pending_workers:
            print(
                f"Warning: {self.pending_workers} worker(s) were still inside a DNS call after shutdown wait; "
                "they are not scheduling new work and should exit at resolver timeout.",
                file=sys.stderr,
            )
            if exit_code == 0:
                exit_code = 2

        if exit_code == 0:
            total_samples = sum(int(s.snapshot()["samples"]) for s in self.states)
            if total_samples == 0:
                exit_code = 1
        return exit_code


